# ==========================================================================
# Configuração do sistema — Tiago Neves Advocacia Empresarial
# Copie para .env e ajuste os valores. NUNCA versione o .env real.
# ==========================================================================

# --- Identidade ---
ESCRITORIO_NOME=Tiago Neves Advocacia Empresarial

# --- Domínio e HTTPS (proxy Caddy) ---
DOMAIN=tiagonevesadv.com.br
ACME_EMAIL=tiagoneves.jus@gmail.com

# --- Django (produção) ---
# Gere uma chave forte: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=False
ALLOWED_HOSTS=tiagonevesadv.com.br,www.tiagonevesadv.com.br
CSRF_TRUSTED_ORIGINS=https://tiagonevesadv.com.br,https://www.tiagonevesadv.com.br
# O Caddy já faz o redirecionamento http->https; mantenha False para evitar loop.
SECURE_SSL_REDIRECT=False

# --- Administrador (criado automaticamente no primeiro start) ---
ADMIN_USERNAME=tiago
ADMIN_PASSWORD=troque-esta-senha
ADMIN_EMAIL=tiagoneves.jus@gmail.com

# --- Banco de dados (PostgreSQL) ---
POSTGRES_DB=juriai
POSTGRES_USER=juriai
POSTGRES_PASSWORD=troque-esta-senha-do-banco
POSTGRES_PORT=5432

# --- IA: respostas com Claude (Anthropic) ---
ANTHROPIC_API_KEY=
IA_CLAUDE_MODEL=claude-opus-4-8

# --- IA: embeddings da busca (backend: local | openai | voyage) ---
# 'local' precisa do stack completo (requirements.txt). Na imagem base, use 'openai'.
IA_EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
# VOYAGE_API_KEY=
